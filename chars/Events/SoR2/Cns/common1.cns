trigger1 = Var(5) = 20
value = 8614
ctrl = 0

[State 150, Hi to Lo]
type = StateTypeSet
triggerall = IsHelper
trigger1 = !HitShakeOver
trigger1 = Time >= 1
;trigger1 = FVar(34) >= 1
;trigger1 = GameTime%3 = 0
;trigger1 = Var(58) >= 501-(Var(1)*20)
trigger1 = InGuardDist; || P2Dist X = [1,150]
trigger1 = Enemynear, MoveType = A
trigger1 = Enemynear, StateType = C
statetype = C
physics = C

[State 150, Lo to Hi]
type = StateTypeSet
triggerall = IsHelper
trigger1 = !HitShakeOver
trigger1 = Time >= 1
;trigger1 = FVar(34) >= 1
;trigger1 = GameTime%3 = 0
;trigger1 = Var(58) >= 501-(Var(1)*20)
trigger1 = InGuardDist; || P2Dist X = [1,150]
trigger1 = Enemynear, MoveType = A
trigger1 = Enemynear, StateType != C
statetype = S
physics = S

[State 150, 2]
type = ChangeState
triggerall = IsHelper
trigger1 = HitShakeOver
trigger2 = Time = 120
value = 151 + 2*(StateType = C)
