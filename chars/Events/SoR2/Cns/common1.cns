; Air guard (guarding)
[Statedef 132]
type    = A
physics = N

;Just in case
[State 150, 6]
type = ChangeState
trigger1 = IsHelper
trigger1 = Time > 0
trigger1 = root, Var(43) != 4
value = 5050 ;Idle

;Helper Guard Start
[State 0, VelSet]
type = VelSet
