;root, Var(51) = Overall difficulty
;(Affects SoR2 Enemy Life, Speed, and Intelligence)
;-- 0 = Novice (Stats -45%)
;-- 1 = Very Easy (Stats -30%
;-- 2 = Easy (Stats -15%)
;-- 3 = Normal
;-- 4 = Hard (Stats +15%)
;-- 5 = Very Hard (Stats +30%)
;-- 6 = Mania (Stats +45%)
;-- 7 = Chaos (Stats +60%)

;Difficulty Stat Changes
[State 9502, StatSet]
type = Null
triggerall = Time = 1
trigger1 = root, Var(51) = 0 ;Novice
trigger1 = Var(1) := (Var(1)-45) ;Intelligence
trigger1 = FVar(0) := (FVar(0)*0.55) ;Max HP
trigger1 = FVar(2) := (FVar(2)*0.55) ;Walk Speed
trigger1 = FVar(39) := 0.55
;-----
trigger2 = root, Var(51) = 1 ;Very Easy
trigger2 = Var(1) := (Var(1)-30) ;Intelligence
trigger2 = FVar(0) := (FVar(0)*0.4) ;Max HP
trigger2 = FVar(2) := (FVar(2)*0.4) ;Walk Speed
trigger2 = FVar(39) := 0.4
;-----
trigger3 = root, Var(51) = 2 ;Easy
trigger3 = Var(1) := (Var(1)-15) ;Intelligence
trigger3 = FVar(0) := (FVar(0)*0.7) ;Max HP
trigger3 = FVar(2) := (FVar(2)*0.7) ;Walk Speed
trigger3 = FVar(39) := 0.7
;-----
trigger4 = root, Var(51) = 4 ;Hard
trigger4 = Var(1) := (Var(1)+14) ;Intelligence
;trigger4 = FVar(0) := (FVar(0)*1.15) ;Max HP
trigger4 = FVar(2) := (FVar(2)*1.2) ;Walk Speed
trigger4 = FVar(39) := 1.2
;-----
trigger5 = root, Var(51) = 5 ;Very Hard
trigger5 = Var(1) := (Var(1)+28) ;Intelligence
;trigger5 = FVar(0) := (FVar(0)*1.3) ;Max HP
trigger5 = FVar(2) := (FVar(2)*1.4) ;Walk Speed
trigger5 = FVar(39) := 1.4
;-----
trigger6 = root, Var(51) = 6 ;Mania
trigger6 = Var(1) := (Var(1)+42) ;Intelligence
;trigger6 = FVar(0) := (FVar(0)*1.45) ;Max HP
trigger6 = FVar(2) := (FVar(2)*1.6) ;Walk Speed
trigger6 = FVar(39) := 1.6
;-----
;trigger7 = root, Var(51) = 7 ;Chaos
;trigger7 = Var(1) := (Var(1)+24) ;Intelligence
;;trigger7 = FVar(0) := (FVar(0)*1.6) ;Max HP
;trigger7 = FVar(2) := (FVar(2)*1.6) ;Walk Speed
;trigger7 = FVar(39) := 1.6
;;-----
;trigger8 = root, Var(51) = 8 ;Extreme
;trigger8 = Var(1) := (Var(1)+30) ;Intelligence
;;trigger8 = FVar(0) := (FVar(0)*1.75) ;Max HP
;trigger8 = FVar(2) := (FVar(2)*1.75) ;Walk Speed
;trigger8 = FVar(39) := 1.75
;;-----
;trigger9 = root, Var(51) = 9 ;Expert
;trigger9 = Var(1) := (Var(1)+36) ;Intelligence
;;trigger9 = FVar(0) := (FVar(0)*1.9) ;Max HP
;trigger9 = FVar(2) := (FVar(2)*1.9) ;Walk Speed
;trigger9 = FVar(39) := 1.9
;;-----
;trigger10 = root, Var(51) = 10 ;Master
;trigger10 = Var(1) := (Var(1)+42) ;Intelligence
;;trigger10 = FVar(0) := (FVar(0)*2.05) ;Max HP
;trigger10 = FVar(2) := (FVar(2)*2.05) ;Walk Speed
;trigger10 = FVar(39) := 2.05
;-----
trigger7 = root, Var(51) = -1 ;Super Easy
trigger7 = Var(1) := (Var(1)-60) ;Intelligence
trigger7 = FVar(0) := (FVar(0)*0.4) ;Max HP
trigger7 = FVar(2) := (FVar(2)*0.4) ;Walk Speed
trigger7 = FVar(39) := 0.4

