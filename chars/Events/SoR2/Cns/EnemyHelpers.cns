;Also contains some other states such as the Fake KO states.

;Things to add for new mini-bosses
;-------------------------------
;Blocking State controllers [x]
;Item pick-up anims [x]
;Throw escape anims [x]
;Shoulder throw anims [x]
;Landing when hitting ground after hit in air (non-knockdown attack) [x]
;Change mini-boss anims to match boss anims [ ]
;Change Anims of boss states to show mini-boss anim instead of normal anim
;Bomber: Special flying state controllers and recovery states
;Nail: Special get-up state anim/action

;---------------------------------------------------------------------------
;PowerUp's State
[Statedef 8015]
type    = A
movetype= I
physics = N
;anim = 9500
velset = 0,0

[State 8020, NotHitBy]
type = NotHitBy
trigger1 = 1
value = SCA
time = 2

[State 8015, AssertSpecial]
type = AssertSpecial
trigger1 = 1
flag = invisible

;Recovery Sound
[State 8015, PlaySnd]
type = PlaySnd
trigger1 = Time = 0
trigger1 = Anim = 2003 || Anim = 2004 || Anim = 500 || Anim = 501 || Anim = 502
value = 201,7

;Points for excess life (Cola)
[State 8015, ParentVarAdd]
type = ParentVarAdd
triggerall = Time < 1
triggerall = NumTarget(8000) > 0
trigger1 = Anim = 500
trigger1 = (Target(8000), Life) > Floor((Target(8000), LifeMax)*0.84)
;trigger1 = 160 > ((Target(8000), LifeMax) - (Target(8000), Life))
v = 56
value = Floor(1000*((((Target(8000), Life)+0.0)/(Target(8000), LifeMax))*0.16))
persistent = 0

;Points for excess life (Hamburger)
[State 8015, ParentVarAdd]
type = ParentVarAdd
triggerall = Time < 1
triggerall = NumTarget(8000) > 0
trigger1 = Anim = 501
trigger1 = (Target(8000), Life) > Floor((Target(8000), LifeMax)*0.5);0.6
v = 56
value = Floor(1000*((((Target(8000), Life)+0.0)/(Target(8000), LifeMax))*0.5));0.4
persistent = 0

;Points for excess life (Medkit)
[State 8015, ParentVarAdd]
type = ParentVarAdd
triggerall = Time < 1
triggerall = NumTarget(8000) > 0
trigger1 = Anim = 502
trigger1 = (Target(8000), Life) > Floor((Target(8000), LifeMax)*0.25)
v = 56
value = Floor(1000*((((Target(8000), Life)+0.0)/(Target(8000), LifeMax))*0.75))
persistent = 0

;Points for excess life (Apple)
[State 8015, ParentVarAdd]
type = ParentVarAdd
triggerall = Time < 1
triggerall = NumTarget(8000) > 0
trigger1 = Anim = 2003
trigger1 = (Target(8000), Life) > Floor((Target(8000), LifeMax)/1.5)
v = 56
value = Floor(1000*((((Target(8000), Life)+0.0)/(Target(8000), LifeMax))/3.0))
persistent = 0

;Points for excess life (Chicken)
[State 8015, ParentVarAdd]
type = ParentVarAdd
triggerall = Time < 1
triggerall = NumTarget(8000) > 0
trigger1 = Anim = 2004
trigger1 = (Target(8000), Life) > 0;Floor((Target(8000), LifeMax)/1.5)
v = 56
value = Floor(1000*((((Target(8000), Life)+0.0)/(Target(8000), LifeMax))/1.0))
persistent = 0

