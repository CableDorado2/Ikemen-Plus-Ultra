persistent = 0

;Current Special Effects
;1 - Regeneration (+10 life every second)
;2 - Armor (-25% damage taken, -50% speed)
;3 - Berserk (+50% damage given AND taken, +10 intelligence)
;4 - Anti-Projectile (Can't be hit by projectiles)
;5 - Evasion (10% chance -33% damage, 10% chance -66% damage, 10% chance -100% damage)
;6 - X-Berserk (Heavy damage increase, but very low life)
;7 - Recon (Enemy strength meter slowly regenerates)
;8 - EX Bomb (Enemy drops 3 grenades upon defeat)
;9 - Jammer (Enemy HUD area is covered by a black fuzz)
;10 - Shield (Absorbs damage instead of life decreasing. Takes 5 less damage from 20+ power attacks, -50% from all others. Random strength.)
;11 - Stealth (Immune to Normal Attacks while Cloaked. -25% Life.)

;---

