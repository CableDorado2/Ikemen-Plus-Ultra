;Var(0) = Enemy
;Var(1) = Intelligence (1-25)
;Var(2) = Enemy Variant (Increases Max Life, but not damage dealt) Not used yet
;Var(3) = Special Ability (0 = No Ability)

;Var(10) = Quick KO Bonus Score (KO enemy quick to get points equal to this value)

;Var(21) = Random Damage Modifier (For Evasion special effects)

;Var(30) = Damage Tracker 1/3
;Var(31) = Damage Tracker 2/3
;Var(32) = Damage Tracker 3/3
;Var(33) = HitCount
;Var(34) = In normal hitstate (Unused, gets set to 40725 while in 5000 States)

;Var(40) = Counter Hit (Self) Check
;Var(41) = Special ID (6830787)
;Var(42) = Roo Successful ender attack from throw
;Var(43) = Roo Life Loss
;Var(44) = Roo Special Meter
;Var(45) = Hit Confirm (Big-Ben, Jack)
;Var(46) = Fog on MotorCycle (1 = Yes, when hit causes the motorcycle to keep going, fall down, and explode)
;Var(47) = Number of attacks by Fog (While on Motorcycle) ||| Number of Attacks (Roo)
;Var(48) = Specific Attack Cooldown (Always drops by 1 every frame, only used to limit use of some attacks)
;Var(49) = Reduced attack frequency (1 = Yes)
;Var(50) = Jet Fly Mode
;Var(51) = Attack Cooldown (Drop by 1 every frame while not attacking, 2 while being hit)
;Var(52) = Time in hitstate
;Var(53) = Boss Invnicible Timer (From Knockdown or excessive hits when facing 2 opponents)
;Var(54) = Weapon Equipped? 1 = Yes
;Var(55) = Guard End Time
;Var(56) = Enemy Throw Escape Counter
;Var(57) = Guard Cooldown
;Var(58) = Attack randomizer
;Var(59) = Used in place of sysvar(1) in some custom hitstates

;FVar(0) = Max Life
;FVar(1) = Current Life
;FVar(2) = Walk Speed

;FVar(36) = Total damage taken from current enemy combo
;FVar(37) = Damage Modifier from special effects
;FVar(38) = Bonus point multiplier for combo hits against enemy
;FVar(39) = Difficulty Multiplier (Used to determine some other things)

;Sprite # Guide
;10000 - Idle (Only if true idle pose/sprite exists that isn't part of walking anim)
;10001 - Walk
;10002 - 10021: All other sprites
;10022 - Portrait
;10023 - Blocking (if it exists)
;10024 - Hit Up into the air (if it exists)
;10025 - Falling/Flying away from hit/KO
;10026 - Hit High
;10027 - Hit Low
;10028 - LieDown
;10029 - GetUp

;Anim # Guide
;10000*Var(0) - Idle
;10001*Var(0) - Walk
;10002 - 10021: All other anim
;10022*Var(0) - Portrait
;10023*Var(0) - Blocking (if it exists)
;10024*Var(0) - Hit Up into the air (if it exists)
;10025*Var(0) - Falling/Flying away from hit/KO
;10026*Var(0) - Hit High
;10027*Var(0) - Hit Low
;10028*Var(0) - LieDown
;10029*Var(0) - GetUp

;root, Var(51) = Overall difficulty
;(Affects SoR2 Enemy Life, Speed, and Intelligence)
;-- 0 = Novice (Stats -45%)
;-- 1 = Very Easy (Stats -30%
;-- 2 = Easy (Stats -15%)
;-- 3 = Normal
;-- 4 = Hard (Stats +15%)
;-- 5 = Very Hard (Stats +30%)
;-- 6 = Mania (Stats +45%)
;-- 7 = Chaos (Stats +60%)

;Difficulty Stat Changes
[State 9502, StatSet]
type = Null
triggerall = Time = 1
trigger1 = root, Var(51) = 0 ;Novice
trigger1 = Var(1) := (Var(1)-45) ;Intelligence
trigger1 = FVar(0) := (FVar(0)*0.55) ;Max HP
trigger1 = FVar(2) := (FVar(2)*0.55) ;Walk Speed
trigger1 = FVar(39) := 0.55
;-----
trigger2 = root, Var(51) = 1 ;Very Easy
trigger2 = 1 || Var(1) := (Var(1)-30) ;Intelligence
trigger2 = FVar(0) := (FVar(0)*0.4) ;Max HP
trigger2 = FVar(2) := (FVar(2)*0.7) ;Walk Speed
trigger2 = FVar(39) := 0.4
;-----
trigger3 = root, Var(51) = 2 ;Easy
trigger3 = 1 || Var(1) := (Var(1)-15) ;Intelligence
trigger3 = FVar(0) := (FVar(0)*0.7) ;Max HP
trigger3 = FVar(2) := (FVar(2)*0.85) ;Walk Speed
trigger3 = FVar(39) := 0.7
;-----
trigger4 = root, Var(51) = 4 ;Hard
trigger4 = Var(1) := (Var(1)+10) ;Intelligence
;trigger4 = FVar(0) := (FVar(0)*1.15) ;Max HP
trigger4 = FVar(2) := (FVar(2)*1.2) ;Walk Speed
trigger4 = FVar(39) := 1.2
;-----
trigger5 = root, Var(51) = 5 ;Very Hard
trigger5 = Var(1) := (Var(1)+20) ;Intelligence
;trigger5 = FVar(0) := (FVar(0)*1.3) ;Max HP
trigger5 = FVar(2) := (FVar(2)*1.4) ;Walk Speed
trigger5 = FVar(39) := 1.4
;-----
trigger6 = root, Var(51) = 6 ;Mania
trigger6 = Var(1) := (Var(1)+30) ;Intelligence
;trigger6 = FVar(0) := (FVar(0)*1.45) ;Max HP
trigger6 = FVar(2) := (FVar(2)*1.6) ;Walk Speed
trigger6 = FVar(39) := 1.6
;-----
;trigger7 = root, Var(51) = 7 ;Chaos
