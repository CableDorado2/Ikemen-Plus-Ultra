;Var(0) = Enemy
;Var(1) = Intelligence (1-25)
;Var(2) = Enemy Variant (Increases Max Life, but not damage dealt) Not used yet - Might not be needed anymore
;Var(3) = Special Ability (0 = No Ability)
;Var(4) = Out of Generate State? (1 = Yes) (Used to allow enemy life bar to be set instantly to correct size)
;Var(5) = Hits in guard state
;Var(6) = State to change to
;Var(7) = 'Parry' detection result
;0 = No hit
;1 = Hit, target detected
;2 = Guarded
;3 = Hit, no target (due to Parry or other related skill)
;
;

;Var(10) = Quick KO Bonus Score (KO enemy quick to get points equal to this value)
;Var(11) = Custom State? (Set by other characters. Prevents 'follower' from showing fake SoR enemy when said enemy is in a custom state.

;Var(19) = Custom State Detect
;Var(20) = Vehelits ID (21347)
;Var(21) = Random Damage Modifier (For Evasion special effects)

;Var(22) = Poison Timer (Set by enemy custom states. If above 0, apply poison effects. Drops by 1 every frame)
;Var(23) = Boss Breaker Charge (1000 = Ready for Breaker)
;Var(24) = 

;Var(30) = Damage Tracker 1/3
;Var(31) = Damage Tracker 2/3
;Var(32) = Damage Tracker 3/3
;Var(33) = HitCount
;Var(34) = In normal hitstate (Unused, gets set to 40725 while in 5000 States)

;Var(36) = Cloak Time
;Var(37) = Akaiho Style Type (0 = Normal, 1 = Aggressive, 2 = Coward, 3 = Evasion)
;Var(38) = Boss Assist Enemy Flag (1 = Enemy runs away after Boss gets KO'd)
;Var(39) = Shoulder Throw Attempts by target
;Var(40) = Counter Hit (Self) Check
;Var(41) = Special ID 470561329 ---was -> 6830787
;Var(42) = Roo Successful ender attack from throw
;Var(43) = Roo Life Loss / Tiger Blitz Stars / Random Life Change / Shiva Vs SoR Character Check
;Var(44) = Roo Special Meter || Mona/Lisa Team Attack Delay / Shiva Special Meter
;Var(45) = Hit Confirm (Big-Ben, Jack)
;Var(46) = Fog on MotorCycle (1 = Yes, when hit causes the motorcycle to keep going, fall down, and explode)
;Var(47) = Fog Attacks (Motorcycle) || Number of Attacks (Roo) || CWD Akaiho Recover Ability Time Left || Mona/Lisa Atks || Shiva Pummel Atks
;Var(48) = Specific Attack Cooldown (Always drops by 1 every frame, only used to limit use of some attacks)
;Var(49) = Reduced attack frequency (1 = Yes)
;Var(50) = Jet Fly Mode
;Var(51) = Attack Cooldown (Drop by 1 every frame while not attacking, 2 while being hit)
;Var(52) = Time in hitstate
;Var(53) = Boss Invincible Timer (From Knockdown or excessive hits when facing 2 opponents)
;Var(54) = Weapon Equipped? 1 = Yes
;Var(55) = Guard End Time
;Var(56) = Enemy Throw Escape Counter
;Var(57) = Guard Cooldown
;Var(58) = Attack randomizer
;Var(59) = Used in place of sysvar(1) in some custom hitstates

;FVar(0) = Max Life
;FVar(1) = Current Life
;FVar(2) = Walk Speed

;FVar(3) = X-Scale
;FVar(4) = Y-Scale

;FVar(21) = Anti-Range Defense (If active, set to 0.35 for damage taken unless a player is nearby)
;FVar(22) = Special Damage Taken Multiplier for Bosses (if used, reduces damage taken instead of boosting life from the 'Extra damage mulitplier')
;FVar(23) = Shiva Block Meter
;FVar(24) = Attack Power Drop from difficulty (Easy = 0.75, Very Easy = 0.5)

;FVar(25) = GetHitVar(XVel)
;FVar(26) = Stagger Damage

;FVar(27) = Poison Strength (Every frame drop life by this amount if poisoned. Set by enemy custom states)

;FVar(28) = Damage Taken (Used in default hit states)
;FVar(29) = Secondary Damage Tracker 1
;FVar(30) = Secondary Damage Tracker 2
;FVar(31) = Secondary Damage Tracker 3

;FVar(32) = Shield Strength (Special effect, max is 1000)
;FVar(33) = Block Damage Mulitplier (If damage mulitplier in config file is above 1, reduce the impact of it for blocked attacks)
;FVar(34) = Block Limit
;FVar(35) = Regeneration for Tiger's Blitz Stars
;FVar(36) = Total damage taken from current enemy combo
;FVar(37) = Damage Modifier from special effects
;FVar(38) = Bonus point multiplier for combo hits against enemy
;FVar(39) = Difficulty Multiplier (Used to determine some other things)

;Sprite # Guide
;10000 - Idle (Only if true idle pose/sprite exists that isn't part of walking anim)
;10001 - Walk
;10002 - 10021: All other sprites
;10022 - Portrait
;10023 - Blocking (if it exists)
;10024 - Hit Up into the air (if it exists)
;10025 - Falling/Flying away from hit/KO
;10026 - Hit High
;10027 - Hit Low
;10028 - LieDown
;10029 - GetUp

;Anim # Guide
;10000*Var(0) - Idle
;10001*Var(0) - Walk
;10002 - 10021: All other anim
;10022*Var(0) - Portrait
;10023*Var(0) - Blocking (if it exists)
;10024*Var(0) - Hit Up into the air (if it exists)
;10025*Var(0) - Falling/Flying away from hit/KO
;10026*Var(0) - Hit High
;10027*Var(0) - Hit Low
;10028*Var(0) - LieDown
;10029*Var(0) - GetUp

