;Mini-HUD

;---------------------------------------------------------------------------
; Override common states (use same number to override) :
;---------------------------------------------------------------------------

;---------------------------------------------------------------------------
; States that are always executed (use statedef -2)
;---------------------------------------------------------------------------

[Statedef -2]

[State -2, DisplayToClipboard]
type = DisplayToClipboard
trigger1 = IsHelper = 0
trigger1 = RoundState = 2
text = "Difficulty = %d"
params = Var(51)

;Increase Rank at end of match if required KOs are reached.
[State 2501, VarAdd]
type = VarAdd
trigger1 = IsHelper = 0
trigger1 = Var(41) = 4
trigger1 = RoundState = 4
trigger1 = Var(35) >= Var(36)
trigger1 = MatchOver
v = 37
value = 1
ignorehitpause = 1
persistent = 0

;Reset KOs
[State 2501, VarSet]
type = VarSet
trigger1 = IsHelper = 0
trigger1 = Var(41) = 4
trigger1 = RoundState = 4
trigger1 = Var(35) >= Var(36)
trigger1 = MatchOver
v = 35
value = 0
ignorehitpause = 1
persistent = 0

;Var(0) = Helper(201) StateType (0 = S, 1 = C, 2 = A, 3 = L)
;Var(1) = Helper(201) MoveType (0 = I, 1 = A, 2 = H)
;Var(2) = Helper(202) StateType (0 = S, 1 = C, 2 = A, 3 = L)
;Var(3) = Helper(202) MoveType (0 = I, 1 = A, 2 = H)

;Var(4) = Enemy(0) Max Life
;Var(5) = Enemy(0) Current Life
;Var(6) = Enemy Power
;Var(7) = Enemy(1) Max Life
;Var(8) = Enemy(1) Current Life

;[State -3, DisplayToClipboard]
;type = DisplayToClipboard
;trigger1 = IsHelper = 0
;trigger1 = 1
;text = "Var(10) = %d, Var(11) = %d, Var(12) = %d"
;params = Var(10),Var(11),Var(12)

;Var(10) = Helper(200)'s Var(0) (Actual Enemy in play)
;Var(11) = Helper(201)'s Var(0)
;Var(12) = Helper(202)'s Var(0)

;Var(13) = Enemy Strength Used (Increases as enemies are defeated)
;Once Var(13) is greater than or equal to Var(59), enemies stop appearing.
;Once all remaining enemies are defeated after this point, the other player wins.
;This whonky system of having Var(13) go UP and be subtracted from Var(59) to get the remaining enemy strength
;was the result of an early build system I forgot to change.

;Var(14) = Helper(201)'s Facing
;Var(15) = Helper(202)'s Facing
;Var(16) = Helper(201)'s StateNo
;Var(17) = Helper(202)'s StateNo
;Var(18) = Helper(201) Time
;Var(19) = Helper(202) Time

;Var(20) = Mr.X KO'd (Causes any remaining enemies to run offscreen)

;8010, 8011 = IDs of Object Helpers
;Var(21) = Power-Up ID of Object 8010 (Anim)
;Var(22) = Power-Up ID of Object 8011 (Anim)
;Var(23) = Power-Up 8010 Picked Up by SoR Enemy (100 = Yes, makes Helper disappear)
;Var(24) = Power-Up 8011 Picked Up by SoR Enemy (100 = Yes, makes Helper disappear)
;Var(25) = Custom State Anim Change Flag for SoR enemies
;Var(26) = General Bonus Section Flag (0 = Not attempted, 1 = In progress, 2 = Finished)
;Var(27) = Mona/Lisa Team Attack (0 = Off-Can Attempt, -1 = Attempt, Lisa walk left, -2 = Attempt, Lisa walk right, >0 = Inactive/Cancel)
;-3 = Set to -1 or -2 depending on Lisa's Postion to Mona

;Mona/Lisa Team Attack Cooldown
[State -2, VarAdd]
type = VarAdd
triggerall = (StateNo != 3030) && (IsHelper = 0)
trigger1 = Var(27) > 0
v = 27
value = -1

;Reset attempt var if Mona gets hit before the team attack is used
[State -2, VarSet]
type = VarSet
triggerall = (StateNo != 3030) && (IsHelper = 0)
trigger1 = Var(27) < 0
trigger1 = NumHelper(200)
trigger1 = Helper(200), MoveType = H
v = 27
value = 60

;Track Mona/Lisa Distance from each other
[State -2, VarSet]
type = VarSet
triggerall = (StateNo != 3030) && (IsHelper = 0)
trigger1 = NumHelper(200) = 1 && NumHelper(201) = 1
trigger1 = Helper(200), Var(0) = 29
trigger1 = Helper(201), Var(0) = 29
;trigger1 = (Helper(200), Facing) = (Helper(201), Facing)
fv = 22
value = (Helper(200), Pos X) - (Helper(201), Pos X)

[State -2, VarSet]
type = VarSet
triggerall = (StateNo != 3030) && (IsHelper = 0)
trigger1 = NumHelper(200) = 1 && NumHelper(202) = 1
trigger1 = Helper(200), Var(0) = 29
trigger1 = Helper(202), Var(0) = 29
;trigger1 = (Helper(200), Facing) = (Helper(201), Facing)
fv = 22
value = (Helper(200), Pos X) - (Helper(202), Pos X)

;Lisa walks left for Team Attack with Mona
[State -2, VarSet]
type = VarSet
triggerall = (StateNo != 3030) && (IsHelper = 0)
triggerall = Var(27) = -2 || Var(27) = -3;Set by Mona in Alt Idle State
trigger1 = NumHelper(200) = 1 && NumHelper(201) = 1
trigger1 = Helper(200), Var(0) = 29
trigger1 = Helper(201), Var(0) = 29
trigger1 = (Helper(200), Pos X) > (Helper(201), Pos X)
;-------
trigger2 = NumHelper(200) = 1 && NumHelper(202) = 1
trigger2 = Helper(200), Var(0) = 29
trigger2 = Helper(202), Var(0) = 29
trigger2 = (Helper(200), Pos X) > (Helper(202), Pos X)  
v = 27
value = -1

;Lisa walks right for Team Attack with Mona
[State -2, VarSet]
type = VarSet
triggerall = (StateNo != 3030) && (IsHelper = 0)
triggerall = Var(27) = -1 || Var(27) = -3;Set by Mona in Alt Idle State
trigger1 = NumHelper(200) = 1 && NumHelper(201) = 1
trigger1 = Helper(200), Var(0) = 29
trigger1 = Helper(201), Var(0) = 29
trigger1 = (Helper(200), Pos X) < (Helper(201), Pos X)
;-------
trigger2 = NumHelper(200) = 1 && NumHelper(202) = 1
trigger2 = Helper(200), Var(0) = 29
trigger2 = Helper(202), Var(0) = 29
trigger2 = (Helper(200), Pos X) < (Helper(202), Pos X)  
v = 27
value = -2

;Var(28) = Special Value for compatibility against certain characters

;Vs. ohgaki's characters. Stun Reset Part 1 (Part 2 is on the characters themselves)
[State -2, VarSet]
type = VarSet
triggerall = IsHelper = 0
triggerall = NumEnemy > 0
triggerall = Enemy(0), authorname = "ohgaki"
triggerall = Enemy(0), Var(10) >= 100
trigger1 = NumHelper(200) = 1
trigger1 = Helper(200), StateNo = [80099,80100]
trigger2 = NumHelper(201) = 1
trigger2 = Helper(201), StateNo = [80099,80100]
trigger3 = NumHelper(202) = 1
trigger3 = Helper(202), StateNo = [80099,80100]
v = 28
value = 5

[State -2, VarSet]
type = VarSet
triggerall = IsHelper = 0
triggerall = NumEnemy > 1
triggerall = Enemy(1), authorname = "ohgaki"
triggerall = Enemy(1), Var(10) >= 100
trigger1 = NumHelper(200) = 1
trigger1 = Helper(200), StateNo = [80099,80100]
trigger2 = NumHelper(201) = 1
trigger2 = Helper(201), StateNo = [80099,80100]
trigger3 = NumHelper(202) = 1
trigger3 = Helper(202), StateNo = [80099,80100]
v = 28
value = 5

[State -2, VarAdd]
type = VarAdd
triggerall = IsHelper = 0
trigger1 = Var(28) = [1,5]
v = 28
value = -1

;Var(34) = Player 2 Lives
;Var(35) = Current Points (Ranked Mode)
;Var(36) = Points required for RankUp
;Var(37) = Current Rank (Starts at 0 for '-' rank (unranked))
;Var(38) = Boss Life Multiplier Flag (1 = Multiply Boss/Mini-Boss Life by Damage Multiplier)
;Var(39) = Normal Enemy Random Life Boost (0 = Off, 1-6 = On)
;Var(40) = Fake KO Get-up type (0 = Normal, 1 = Quick)
;Var(41) = Bonus Game Mode (0 = Normal, 1 = Boss Rush Mode, 2 = Speed Run Mode)
;Var(42) = Max # of enemy block attempts
;Var(43) = Enemy Block Type (0 = Reaction Only, 1 = SoR Style, 4 = MUGEM System)
;Var(44) = Enemy Abilites (1 = Enemies can appear with special abilites)
;Var(45) = Infinite Lives Mode (1 = On)
;Var(46) = MiniBosses defeated
;Var(47) = Enemy Item Pick Up
;Var(48) = Item Layer Type
;Var(49) = Currently unused
;Var(50) = Enemy Hit Type (HitOverrides)
;Var(51) = Difficulty (Affects SoR2 Enemy Life, Speed, and Intelligence)
;-- 1 = Very Easy, 2 = Easy, 3 = Normal
;-- 4 = Hard, 5 = Very Hard, 6 = Mania
;Var(52) = Extra Enemy Intelligence
;Var(53) = Auto-Pickup
;Var(54) = HUD Type (0 = Completely off, 1 = Mini-HUD, 2 = Full Custom HUD)
;Var(55) = Bosses defeated.
;Var(56) = Score
;Var(57) = Lives for opponent
;Var(58) = Round lost? If greater than 0, yes
;Var(59) = Max Enemy Strength

;FVar(6) = Helper(201) X-Position
;FVar(7) = Helper(201) Y-Position
;FVar(8) = Helper(202) X-Position
;FVar(9) = Helper(202) Y-Position

;FVar(10) = Helper(200)'s FVar(0) (Max Life)
;FVar(11) = Helper(200)'s FVar(1) (Current Life)
;FVar(12) = Helper(201)'s FVar(0) (Max Life)
;FVar(13) = Helper(201)'s FVar(1) (Current Life)
;FVar(14) = Helper(202)'s FVar(0) (Max Life)
;FVar(15) = Helper(202)'s FVar(1) (Current Life)

;FVar(16) = Distance between Helper(200) and Object 8010
;FVar(17) = Distance between Helper(201) and Object 8010
;FVar(18) = Distance between Helper(202) and Object 8010

;FVar(19) = Distance between Helper(200) and Object 8011
;FVar(20) = Distance between Helper(201) and Object 8011
;FVar(21) = Distance between Helper(202) and Object 8011

;FVar(22) = Distance between Mona & Lisa

;FVar(23) = Time remaining for Star Rank

;FVar(24) = Pos X of Power Up 8010
;FVar(25) = Pos X of Power Up 8011

;Pos X of Helper(8010)
[State -2, VarSet]
type = VarSet
triggerall = IsHelper = 0
trigger1 = RoundState = 2
trigger1 = NumHelper(8010) > 0
trigger1 = ((Helper(8010), Anim) = [2000,2004]) || ((Helper(8010), Anim) = [500,502])
fv = 24
value = Helper(8010), Pos X
ignorehitpause = 1

;If Helper(8010) does not exist or has not been hit yet to reveal an item, set variable to 9999
[State -2, VarSet]
type = VarSet
triggerall = IsHelper = 0
triggerall = RoundState = 2 
triggerall = FVar(24) != 9999
trigger1 = NumHelper(8010) = 0
trigger2 = NumHelper(8010) > 0
trigger2 = ((Helper(8010), Anim) != [2000,2004]) && ((Helper(8010), Anim) != [500,502])
fv = 24
value = 9999
ignorehitpause = 1

;Pos X of Helper(8011)
[State -2, VarSet]
type = VarSet
triggerall = IsHelper = 0
trigger1 = RoundState = 2
trigger1 = NumHelper(8011) > 0
trigger1 = ((Helper(8011), Anim) = [2000,2004]) || ((Helper(8011), Anim) = [500,502])
fv = 25
value = Helper(8011), Pos X
ignorehitpause = 1

;If Helper(8011) does not exist or has not been hit yet to reveal an item, set variable to 9999
[State -2, VarSet]
type = VarSet
triggerall = IsHelper = 0
triggerall = RoundState = 2 
triggerall = FVar(25) != 9999
trigger1 = NumHelper(8011) = 0
trigger2 = NumHelper(8011) > 0
trigger2 = ((Helper(8011), Anim) != [2000,2004]) && ((Helper(8011), Anim) != [500,502])
fv = 25
value = 9999
ignorehitpause = 1


;FVar(37) = Time passed (For Speed run mode, increases by 0.05 every frame, except for some states.)
;FVar(38) = Custom Damage Multiplier
;FVar(39) = Enemy Block Charge

