; Introduction
; CNS difficulty: basic
[Statedef 191]
type = S
ctrl = 0
anim = 190
velset = 0,0

[State 191, 1] ;Freeze animation until PreIntro is over
type = ChangeAnim
trigger1 = RoundState = 0
value = 190

[State 191, 2] ;Assert this until you want "round 1, fight" to begin
type = AssertSpecial
trigger1 = 1
flag = Intro

;Max Lives
[State 191, VarSet]
type = VarSet
trigger1 = RoundNo = 1
trigger1 = Var(57) > 9
trigger1 = Time = 145
v = 57
value = 9

;Double opponent starting lives if opponent is in Simul mode (can go above 9)
[State 191, VarAdd]
type = VarAdd
trigger1 = RoundNo = 1
trigger1 = Time = 150
trigger1 = NumEnemy > 0
trigger1 = Enemy, Teammode = Simul
v = 57
value = Var(57)

;Give opponent 2 starting lives if starting lives is 0 and opponent teammode is Simul
[State 191, VarSet]
type = VarSet
trigger1 = RoundNo = 1
trigger1 = Time = 155
trigger1 = NumEnemy > 0
trigger1 = Enemy, Teammode = Simul
trigger1 = Var(57) < 2
v = 57
value = 2

