;root, Var(51) = Overall difficulty
;(Affects SoR2 Enemy Life, Speed, and Intelligence)
;-- 0 = Novice (Stats -45%)
;-- 1 = Very Easy (Stats -30%
;-- 2 = Easy (Stats -15%)
;-- 3 = Normal
;-- 4 = Hard (Stats +15%)
;-- 5 = Very Hard (Stats +30%)
;-- 6 = Mania (Stats +45%)
;-- 7 = Chaos (Stats +60%)

;Difficulty Stat Changes
[State 9502, StatSet]
type = Null
triggerall = Time = 2
trigger1 = root, Var(51) = 0 ;Novice
trigger1 = Var(1) := (Var(1)-45) ;Intelligence
trigger1 = FVar(0) := (FVar(0)*0.55) ;Max HP
trigger1 = FVar(2) := (FVar(2)*0.55) ;Walk Speed
trigger1 = FVar(39) := 0.55
;-----
trigger2 = root, Var(51) = 1 ;Very Easy
trigger2 = 1 || Var(1) := (Var(1)-30) ;Intelligence
trigger2 = FVar(0) := (FVar(0)*0.4) ;Max HP
trigger2 = FVar(2) := (FVar(2)*0.7) ;Walk Speed
trigger2 = FVar(39) := 0.4
;-----
trigger3 = root, Var(51) = 2 ;Easy
trigger3 = 1 || Var(1) := (Var(1)-15) ;Intelligence
trigger3 = FVar(0) := (FVar(0)*0.7) ;Max HP
trigger3 = FVar(2) := (FVar(2)*0.85) ;Walk Speed
trigger3 = FVar(39) := 0.7
;-----
trigger4 = root, Var(51) = 4 ;Hard
trigger4 = Var(1) := (Var(1)+14) ;Intelligence
;trigger4 = FVar(0) := (FVar(0)*1.15) ;Max HP
trigger4 = FVar(2) := (FVar(2)*1.2) ;Walk Speed
trigger4 = FVar(39) := 1.2
;-----
trigger5 = root, Var(51) = 5 ;Very Hard
trigger5 = Var(1) := (Var(1)+28) ;Intelligence
;trigger5 = FVar(0) := (FVar(0)*1.3) ;Max HP
trigger5 = FVar(2) := (FVar(2)*1.4) ;Walk Speed
trigger5 = FVar(39) := 1.4
;-----
trigger6 = root, Var(51) = 6 ;Mania
trigger6 = Var(1) := (Var(1)+42) ;Intelligence
;trigger6 = FVar(0) := (FVar(0)*1.45) ;Max HP
trigger6 = FVar(2) := (FVar(2)*1.6) ;Walk Speed
trigger6 = FVar(39) := 1.6
;-----

;Difficulty Max Life Change (Over 500 life)
[State 9502, StatSet]
type = Null
triggerall = Time = 1
triggerall = FVar(0) > 500
trigger1 = root, Var(51) = 4 ;Hard
trigger1 = FVar(0) := (FVar(0)+100) ;Max HP
;-----
trigger2 = root, Var(51) = 5 ;Very Hard
trigger2 = FVar(0) := (FVar(0)+200) ;Max HP
;-----
trigger3 = root, Var(51) = 6 ;Mania
trigger3 = FVar(0) := (FVar(0)+300) ;Max HP
;-----
;trigger4 = root, Var(51) = 7 ;Chaos
;trigger4 = FVar(0) := (FVar(0)+200) ;Max HP
;;-----
;trigger5 = root, Var(51) = 8 ;Extreme
;trigger5 = FVar(0) := (FVar(0)+250) ;Max HP
;;-----
;trigger6 = root, Var(51) = 9 ;Expert
;trigger6 = FVar(0) := (FVar(0)+300) ;Max HP
;;-----
;trigger7 = root, Var(51) = 10 ;Master
;trigger7 = FVar(0) := (FVar(0)+350) ;Max HP

;Difficulty Max Life Change (500 life or less)
[State 9502, StatSet]
type = Null
triggerall = Time = 1
triggerall = FVar(0) <= 500
trigger1 = root, Var(51) = 4 ;Hard
trigger1 = FVar(0) := (FVar(0)+50) ;Max HP
;-----
trigger2 = root, Var(51) = 5 ;Very Hard
trigger2 = FVar(0) := (FVar(0)+100) ;Max HP
;-----
trigger3 = root, Var(51) = 6 ;Mania
trigger3 = FVar(0) := (FVar(0)+150) ;Max HP
;-----
;trigger4 = root, Var(51) = 7 ;Chaos
;trigger4 = FVar(0) := (FVar(0)+100) ;Max HP
;;-----
;trigger5 = root, Var(51) = 8 ;Extreme
;trigger5 = FVar(0) := (FVar(0)+125) ;Max HP
;;-----
;trigger6 = root, Var(51) = 9 ;Expert
;trigger6 = FVar(0) := (FVar(0)+150) ;Max HP
;;-----
