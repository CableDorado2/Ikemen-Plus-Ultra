;FVar(10) = General HP
;FVar(11) = Gas Strength (HP)
;FVar(12) = Gas Build Rate

;Gas Strength increases by Gas Build Rate every frame
;Gas Build Rate slowly increases up to 0.25 (0.001)
;Gas Strength decreases by 50% more than the damage that was taken
;Gas Build Rate decreases by damage taken *0.001
;If Gas Build Rate goes negative, Gas Strength stop increasing
;Lowest Gas Build Rate can become is -0.1
;Gas Build Rate can't start increasing right after a hit until HitShake is over
;Gas is Lv.X, where X is +1 for every 1000 HP the Gas Stength has
;General loses HP equal to (0.01*Gas Lv) every frame

[State 21623, VarSet]
type = VarSet
trigger1 = Time = 20
fv = 10
value = 1000

;Mini-Boss Life boost if Damage Multiplier is above 1, and Ratio Fix option is on.
[State 9512, VarSet]
type = VarSet
trigger1 = Time = 1
trigger1 = root, Var(38) = 1
trigger1 = root, Var(41) != 2;Not in Speed Run Mode
trigger1 = root, FVar(38) > 1;Damage Multiplier is above 1
fv = 0
value = FVar(0)*(root,FVar(38))

;-if set above 1, divide bonus amount by that number
[State 9512, VarSet]
type = VarSet
trigger1 = Time = 1
trigger1 = root, Var(38) > 1
trigger1 = root, Var(41) != 2;Not in Speed Run Mode
trigger1 = root, FVar(38) > 1;Damage Multiplier is above 1
fv = 0
value = FVar(0)*(1+((root,FVar(38)-1)/(root, Var(38))))

