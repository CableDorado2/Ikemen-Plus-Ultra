triggerall = NumEnemy = 1
trigger1 = FVar(12) < 6
fv = 12
value = 0.03;0.03

[State 21627, VarAdd]
type = VarAdd
triggerall = NumEnemy > 1
trigger1 = FVar(12) < 10
fv = 12
value = 0.05;0.05

;Gas Build Rate decrease from damage
[State 21627, VarAdd]
