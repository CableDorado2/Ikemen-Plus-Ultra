;大乱闘スマッシュブラサーズ名物のボーナスゲームである　ターゲットを壊せ!!　だと
;ルール設定も出来るんでなんかの大会に使ってみて下さいナ。

;作成 			AlGod(ヨコセイ)

;開発進行度		97%
;----------------------------------------------------------------------------------------------------

[Info]
name         = "Break the Targets_Ver.2"  	;キャラの名前
displayname  = "Break the Targets"	 	;表示されるキャラの名前
versiondate  = 11,22,2000    			;キャラの更新情報
mugenversion = 1,9,2011  			;キャラが動くmugenのバージョン
author       = "AlGod(ヨコセイ)" 			;キャラの製作者名
pal.defaults = 6,3,4,2      			;敵としてでるキャラのパレット

;----------------------------------------------------------------------------------------------------

[Files]

;----------------------------------------------------------------------------------------------------
;◆    共通     ◆
;----------------------------------------------------------------------------------------------------
cmd          = sys/Target_Test.cmd   	 	;キャラのコマンド
cns          = sys/Target_Test.cns    	;キャラののコンタンツステイト
sprite       = sys/Target_Test.sff      ;キャラの絵
anim         = sys/Target_Test.air        	;キャラの動き
sound        = sys/Target_Test.snd   	;キャラの音
;----------------------------------------------------------------------------------------------------
;◆   ステイト   ◆	(最大9まで登録可能)
;----------------------------------------------------------------------------------------------------
st           = st/Break.cns  ;キャラの動作
st0          = st/Target.cns  		;的のステイト
st1	     = st/Config.cns		;コフィングステイト
st2	     = st/Override.cns      ;オーバーライドステイト
stcommon     = common1.cns 		 	;共通ファイル
;----------------------------------------------------------------------------------------------------
;◆カラーパレット◆	(最大12まで登録可能)
;----------------------------------------------------------------------------------------------------
pal1         = pal/blue.act
pal2         = pal/green.act
pal3         = pal/yellow.act
pal4         = pal/flame_red.act
pal5         = pal/red.act
pal6	     = pal/purple.act
pal7         = pal/metal_blue.act
pal8	     = pal/metal_green.act
pal9	     = pal/metal_yellow.act
pal10	     = pal/metal_flame.act
pal11	     = pal/dark_red.act
pal12	     = pal/black.act

