;-| 通常 |-------------------------------------------------------
[Defaults]
command.time = 30
command.buffer.time = 1

;-| 長押し |--------------------------------------------------------------
[Command]
name = "hold_x"
command = /x
time = 1

[Command]
name = "hold_y"
command = /y
time = 1

[Command]
name = "hold_z"
command = /z
time = 1

[Command]
name = "hold_a"
